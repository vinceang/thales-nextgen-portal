# TMDB — used ONLY by scripts/tmdb-snapshot.mjs at snapshot time (build-time),
# never bundled or shipped to the browser. Copy this file to .env.local and paste
# your token. .env.local is git-ignored.
#
#   cp .env.example .env.local
#
# Get a v4 Read Access Token: themoviedb.org → Settings → API →
# "API Read Access Token (v4 auth)". Paste the long token below.
TMDB_READ_TOKEN=
