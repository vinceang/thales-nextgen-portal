#!/bin/sh
# Pre-commit: refresh the media snapshots (TMDB → Watch, Deezer → Listen,
# Open Library → Read) only when stale (>48h).
#
# Guarded + fail-open by design: fresh snapshots skip instantly (no network); a
# missing token / offline / API error warns and lets the commit proceed. It never
# blocks a commit over external data. Shared/versioned via core.hooksPath=.githooks
# (set by `npm run prepare` in portal/).
root="$(git rev-parse --show-toplevel)"
cd "$root/portal" 2>/dev/null || exit 0
[ -f scripts/tmdb-snapshot.mjs ] && node scripts/tmdb-snapshot.mjs --if-stale --stage --max-age-hours 48 || true
[ -f scripts/deezer-snapshot.mjs ] && node scripts/deezer-snapshot.mjs --if-stale --stage --max-age-hours 48 || true
[ -f scripts/openlibrary-snapshot.mjs ] && node scripts/openlibrary-snapshot.mjs --if-stale --stage --max-age-hours 48 || true
exit 0
